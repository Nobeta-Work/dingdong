# Copy this file to .env only when you need to override development defaults.
MYSQL_ROOT_PASSWORD=root_dev
MYSQL_USER=dingdong
MYSQL_PASSWORD=dingdong_dev
MYSQL_PORT=3306
REDIS_PASSWORD=redis_dev
REDIS_PORT=6379
NACOS_PORT=8848
NACOS_CONSOLE_PORT=8085
# Base64-encoded development token required by Nacos 3, even when auth is disabled.
NACOS_AUTH_TOKEN=ZGluZ2RvbmctZGV2ZWxvcG1lbnQtbmFjb3MtdG9rZW4tMjAyNg==
NACOS_AUTH_IDENTITY_KEY=dingdong-identity
NACOS_AUTH_IDENTITY_VALUE=dingdong-dev
# Keep this value identical for Gateway, user-service, product-service and order-service.
JWT_SECRET=dingdong-change-this-development-secret-at-least-32-bytes
ROCKETMQ_NAMESRV_ADDR=127.0.0.1:9876
ROCKETMQ_PAYMENT_SUCCESS_TOPIC=payment-success
ROCKETMQ_ORDER_TIMEOUT_TOPIC=order-timeout
OUTBOX_RETRY_DELAY_MS=60000
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
PRODUCT_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
PAY_SERVICE_PORT=8084
CORS_ALLOWED_ORIGIN_LOCALHOST=http://localhost:*
CORS_ALLOWED_ORIGIN_LOOPBACK=http://127.0.0.1:*
